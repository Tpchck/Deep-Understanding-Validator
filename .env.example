# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── AI providers ─────────────────────────────────────────
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=                          # optional — only needed if you switch to Gemini

# ── Feature flags ────────────────────────────────────────
USE_MOCK_AI=false                        # set true to skip real LLM calls during dev
STORAGE_MODE=supabase                    # "temp" or "supabase"
NEXT_PUBLIC_SITE_URL=http://localhost:3000 # deployment URL (e.g. https://your-domain.com)
